# ──────────────────────────────────────────────────────────────
# ArchiLink — environment variables
#
# Copy this file to `.env.local` and fill in real values when
# you want to connect to Supabase. Without these vars the site
# still boots — public pages just render empty/placeholder data.
# ──────────────────────────────────────────────────────────────

# Supabase (auth + database + storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# UploadThing (file uploads — only needed if you upload images)
UPLOADTHING_TOKEN=

# Resend (transactional email — only needed for notifications)
RESEND_API_KEY=

# Sentry (error tracking — only enabled in production)
NEXT_PUBLIC_SENTRY_DSN=
